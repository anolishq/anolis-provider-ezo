{
  "version": 2,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "ANOLIS_PROVIDER_EZO_WARNINGS_AS_ERRORS": "OFF"
      }
    },
    {
      "name": "base-windows-msvc",
      "hidden": true,
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_HOST_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "dev-debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "dev-release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "dev-linux-hardware-debug",
      "inherits": "dev-debug"
    },
    {
      "name": "dev-linux-hardware-release",
      "inherits": "dev-release"
    },
    {
      "name": "dev-windows-debug",
      "inherits": "base-windows-msvc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "dev-windows-release",
      "inherits": "base-windows-msvc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev-debug",
      "configurePreset": "dev-debug"
    },
    {
      "name": "dev-release",
      "configurePreset": "dev-release"
    },
    {
      "name": "dev-linux-hardware-debug",
      "configurePreset": "dev-linux-hardware-debug"
    },
    {
      "name": "dev-linux-hardware-release",
      "configurePreset": "dev-linux-hardware-release"
    },
    {
      "name": "dev-windows-debug",
      "configurePreset": "dev-windows-debug",
      "configuration": "Debug"
    },
    {
      "name": "dev-windows-release",
      "configurePreset": "dev-windows-release",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "dev-debug",
      "configurePreset": "dev-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-release",
      "configurePreset": "dev-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-linux-hardware-debug",
      "configurePreset": "dev-linux-hardware-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-linux-hardware-release",
      "configurePreset": "dev-linux-hardware-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-windows-debug",
      "configurePreset": "dev-windows-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-windows-release",
      "configurePreset": "dev-windows-release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
